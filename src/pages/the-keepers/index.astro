---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="The Keepers"
  description="The Keepers: What the Stones Remember — a six-book contemporary fantasy series by R.J. Thornton. Published by Holdfast Press."
>
  <!-- ══════════════════════════════════════════
       SERIES HERO
       ══════════════════════════════════════════ -->
  <section class="series-hero" aria-label="The Keepers series">
    <div class="hero-inner container">
      <p class="hero-label accent">A six-book series</p>
      <h1 class="hero-series display">The Keepers</h1>
      <p class="hero-book display-italic">What the Stones Remember</p>
      <p class="hero-byline accent">by R.J. Thornton &mdash; Published by Holdfast Press</p>
      <div class="hero-mark mark" aria-hidden="true">
        <svg
          viewBox="0 0 100 100"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          width="56"
          height="56"
        >
          <path
            d="M 53.49 10.15 A 40 40 0 1 1 46.51 10.15"
            stroke="currentColor"
            stroke-width="4.5"
            stroke-linecap="round"
          />
        </svg>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       PITCH — 50-word version
       Light section: bone
       ══════════════════════════════════════════ -->
  <section class="pitch-section section" aria-label="Series pitch">
    <div class="pitch-inner container">
      <p class="pitch-text display-italic">
        Hal Bergstrom has spent fifteen years in the same hotel bars with the same brilliant,
        broken, brotherly friends. He thought they were colleagues. He was wrong. They were the
        last of a Viking-era village whose binding has finally failed — and the thing it held
        is hungry.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       BOOK ONE BLURB
       Dark section: stone deep
       ══════════════════════════════════════════ -->
  <section class="blurb-section section" aria-label="Book one blurb">
    <div class="blurb-inner container">
      <p class="blurb-label accent">Book One</p>
      <h2 class="blurb-title">What the Stones Remember</h2>
      <hr class="rule-ember" />

      <div class="blurb-text prose">
        <p>
          The first frost came early to Eikvik that year.
        </p>
        <p>
          Halvard was sixteen winters old the night the seer set a circle of rune-stones in the
          wet sand of the strand and took his name from him. He would not remember the village.
          He would not remember his father standing at the edge of the working with the warmth
          gone out of him already, axe raised toward the trees. He would not remember the girl
          who held his hand inside the rising light and whispered, very quietly, in his ear:
        </p>
        <p class="blurb-find-me"><em>Find me.</em></p>
        <p>
          Twelve hundred years later, Hal Bergstrom — forty-three, widowed, a principal cloud
          architect from Austin — wakes in a San Francisco hotel room with a hotel alarm clock
          beeping in the dark and the certainty that he has just been someone he is not.
        </p>
        <p>
          His friends are starting to dream things they should not be able to dream. A man at a
          conference bar has a face no one can quite remember. A cryptographer in Zurich whose
          silver pendant has waited her whole life to mean something is finally finding the words
          for what she has always almost known.
        </p>
        <p>
          The binding their fathers died to make is failing.
        </p>
        <p>
          The thing beneath it has not forgotten them.
        </p>
        <p>
          And somewhere in the rain over the Outer Hebrides, the stones at Callanish are
          remembering everyone they have ever held.
        </p>
      </div>

      <div class="blurb-theme">
        <p class="theme-line display-italic">&ldquo;What we choose to carry, carries us.&rdquo;</p>
      </div>

      <p class="blurb-comps accent">
        For readers of Stephen R. Lawhead · Erin Morgenstern · Susanna Clarke
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SERIES — all six books
       Light section: bone
       ══════════════════════════════════════════ -->
  <section class="series-books section" aria-label="Books in the series">
    <div class="books-inner container">
      <h2 class="books-heading">The Series</h2>
      <hr class="rule-ember" />
      <ol class="book-list">
        <li class="book-item book-item--current">
          <span class="book-number accent">Book One</span>
          <span class="book-title display-italic">What the Stones Remember</span>
          <span class="book-status accent">Writing now</span>
        </li>
        <li class="book-item">
          <span class="book-number accent">Book Two</span>
          <span class="book-title display-italic">The Mountain That Should Not Wake</span>
          <span class="book-status accent">Outlined</span>
        </li>
        <li class="book-item">
          <span class="book-number accent">Book Three</span>
          <span class="book-title display-italic">The Old Roads</span>
          <span class="book-status accent">Outlined</span>
        </li>
        <li class="book-item">
          <span class="book-number accent">Book Four</span>
          <span class="book-title display-italic">Below the Foundry</span>
          <span class="book-status accent">Planned</span>
        </li>
        <li class="book-item">
          <span class="book-number accent">Book Five</span>
          <span class="book-title display-italic">The Stone Throat of the Andes</span>
          <span class="book-status accent">Planned</span>
        </li>
        <li class="book-item">
          <span class="book-number accent">Book Six</span>
          <span class="book-title display-italic">The Last Council</span>
          <span class="book-status accent">Planned</span>
        </li>
      </ol>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       DREAM CTA
       Dark: stone-deep
       ══════════════════════════════════════════ -->
  <section class="dream-section section" aria-label="Have you had the dream">
    <div class="dream-inner container">
      <p class="dream-rune accent" aria-hidden="true">ᚺᚨᚡᛖ ᛃᛟᚢ ᚺᚨᛞ ᛏᚺᛖ ᛞᚱᛖᚨᛖ</p>
      <h2 class="dream-heading">Have you had the dream?</h2>
      <p class="dream-sub display-italic">Submit your dream. We are listening.</p>
      <form
        class="email-form"
        action="#"
        method="POST"
        aria-label="Newsletter signup"
      >
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          autocomplete="email"
          aria-label="Email address"
        />
        <button type="submit">Send</button>
      </form>
      <p class="dream-note accent">No marketing. Dispatches from the work.</p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Series Hero ── */
  .series-hero {
    background: var(--color-stone-deep);
    color: var(--color-fog);
    padding: var(--space-xl) var(--space-md);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .series-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 50% at 50% 0%,
      rgba(122, 143, 168, 0.08) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-label {
    color: var(--color-stone-mid);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-series {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3rem, 7vw, 5.5rem);
    letter-spacing: 0.12em;
    color: var(--color-fog);
    line-height: 1;
  }

  .hero-book {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 2.5vw, 1.7rem);
    color: var(--color-rune-light);
    letter-spacing: 0.05em;
  }

  .hero-byline {
    color: var(--color-stone-mid);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-mark {
    color: var(--color-stone-mid);
    margin-top: var(--space-sm);
  }

  /* ── Pitch ── */
  .pitch-section {
    background: var(--color-bone);
    color: var(--color-stone-deep);
  }

  .pitch-inner {
    max-width: var(--max-content);
  }

  .pitch-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.2rem, 2.5vw, 1.65rem);
    line-height: 1.7;
    color: var(--color-stone-deep);
  }

  /* ── Blurb ── */
  .blurb-section {
    background: var(--color-stone-deep);
    color: var(--color-fog);
  }

  .blurb-inner {
    max-width: var(--max-content);
  }

  .blurb-label {
    color: var(--color-stone-mid);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .blurb-title {
    font-family: var(--font-header);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    letter-spacing: 0.08em;
    color: var(--color-fog);
  }

  .blurb-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    color: var(--color-fog);
    margin: var(--space-md) 0;
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .blurb-find-me {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--color-bone);
    padding: 0.5rem 0;
  }

  .blurb-theme {
    border-left: 2px solid var(--color-ember);
    padding-left: 1.5rem;
    margin: var(--space-md) 0;
  }

  .theme-line {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--color-bone);
  }

  .blurb-comps {
    color: var(--color-stone-mid);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ── Book List ── */
  .series-books {
    background: var(--color-bone);
    color: var(--color-stone-deep);
  }

  .books-inner {
    max-width: var(--max-content);
  }

  .books-heading {
    font-family: var(--font-header);
    font-size: 0.95rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .book-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: var(--space-md);
  }

  .book-item {
    display: grid;
    grid-template-columns: 6rem 1fr auto;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(58, 63, 74, 0.15);
  }

  .book-item:first-child {
    border-top: 1px solid rgba(58, 63, 74, 0.15);
  }

  .book-item--current .book-title {
    color: var(--color-stone-deep);
    font-weight: 500;
  }

  .book-number {
    color: var(--color-iron);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .book-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-stone-mid);
  }

  .book-status {
    color: var(--color-iron);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .book-item--current .book-status {
    color: var(--color-ember);
    opacity: 1;
  }

  /* ── Dream ── */
  .dream-section {
    background: var(--color-stone-deep);
    color: var(--color-fog);
    text-align: center;
  }

  .dream-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: 600px;
  }

  .dream-rune {
    color: var(--color-stone-mid);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
  }

  .dream-heading {
    font-family: var(--font-header);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    letter-spacing: 0.1em;
    color: var(--color-fog);
  }

  .dream-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-rune-light);
  }

  .dream-note {
    color: var(--color-stone-mid);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .book-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
