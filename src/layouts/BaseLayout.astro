---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Holdfast Press',
  description = 'Holdfast Press — Books that hold. Publisher of The Keepers series by R.J. Thornton.',
  ogImage = '/og-default.jpg',
} = Astro.props;

const fullTitle = title === 'Holdfast Press' ? title : `${title} · Holdfast Press`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@holdfastpress" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <title>{fullTitle}</title>

    <!-- Google Fonts: Cormorant Garamond, Cinzel, Lora, IBM Plex Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Cinzel:wght@400;500;600&family=Lora:ital,wght@0,400;0,500;1,400;1,500&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <!-- Broken-binding mark as home link -->
        <a href="/" class="nav-mark" aria-label="Holdfast Press home">
          <svg
            viewBox="0 0 100 100"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            width="28"
            height="28"
          >
            <!-- A circle of radius 40, centred at 50,50, with a small break at the top -->
            <path
              d="M 53.49 10.15 A 40 40 0 1 1 46.51 10.15"
              stroke="currentColor"
              stroke-width="5"
              stroke-linecap="round"
            />
          </svg>
        </a>

        <a href="/" class="nav-logo">Holdfast Press</a>

        <ul class="nav-links" role="list">
          <li><a href="/the-keepers">The Keepers</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner container">
        <div class="footer-mark mark">
          <svg
            viewBox="0 0 100 100"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            width="32"
            height="32"
          >
            <path
              d="M 53.49 10.15 A 40 40 0 1 1 46.51 10.15"
              stroke="currentColor"
              stroke-width="5"
              stroke-linecap="round"
            />
          </svg>
        </div>
        <p class="footer-imprint">Holdfast Press</p>
        <p class="footer-tagline"><em>Books that hold.</em></p>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="/the-keepers">The Keepers</a>
          <span aria-hidden="true">·</span>
          <a href="/about">About</a>
          <span aria-hidden="true">·</span>
          <a href="https://x.com/holdfastpress" rel="noopener noreferrer" target="_blank">@holdfastpress</a>
        </nav>
        <p class="footer-copy accent">© R.J. Thornton · All rights reserved · holdfastpress.com</p>
      </div>
    </footer>
  </body>
</html>

<style>
  /* ── Site header ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-stone-deep);
    border-bottom: 1px solid var(--color-stone-mid);
  }

  .site-nav {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-mark {
    color: var(--color-rune-light);
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .nav-mark:hover {
    color: var(--color-fog);
  }

  .nav-logo {
    font-family: var(--font-header);
    font-size: 0.9rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-fog);
    text-decoration: none;
    margin-right: auto;
  }
  .nav-logo:hover {
    color: var(--color-bone);
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    font-family: var(--font-header);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-fog);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s, color 0.2s;
  }
  .nav-links a:hover {
    opacity: 1;
    color: var(--color-rune-light);
  }

  /* ── Site footer ── */
  .site-footer {
    background: var(--color-stone-deep);
    color: var(--color-fog);
    padding: var(--space-lg) var(--space-md);
    text-align: center;
    border-top: 1px solid var(--color-stone-mid);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-mark {
    color: var(--color-stone-mid);
    margin-bottom: 0.5rem;
  }

  .footer-imprint {
    font-family: var(--font-header);
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-fog);
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-rune-light);
    margin-bottom: 0.5rem;
  }

  .footer-nav {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-family: var(--font-header);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .footer-nav a {
    color: var(--color-fog);
    opacity: 0.6;
  }
  .footer-nav a:hover {
    opacity: 1;
    color: var(--color-rune-light);
  }
  .footer-nav span {
    color: var(--color-stone-mid);
  }

  .footer-copy {
    color: var(--color-stone-mid);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .site-nav {
      padding: 0.875rem 1.25rem;
    }

    .nav-links {
      gap: 1.25rem;
    }
  }
</style>
